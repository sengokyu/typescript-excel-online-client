{
  "name": "xls-graph-client",
  "version": "0.0.1",
  "author": "sengokyu <sengoyu+gh@gmail.com>",
  "description": "A thin wrapper for Microsoft Excel Graph API",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sengokyu/typescript-excel-online-client.git"
  },
  "keywords": [
    "excel",
    "microsoft",
    "msgraph"
  ],
  "license": "MIT",
  "homepage": "https://github.com/sengokyu/typescript-excel-online-client",
  "readme": "README.md",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:types": "tsc -p tsconfig.build.json",
    "build:esbuild": "node build.mjs",
    "build": "npm run build:types && npm run build:esbuild",
    "test": "vitest run",
    "sample1": "cd samples && npx tsx sample1.ts",
    "sample2": "cd samples && npx tsx sample2.ts"
  },
  "devDependencies": {
    "@microsoft/microsoft-graph-types": "^2.38.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.2",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "@microsoft/kiota-abstractions": "^1.0.0-preview.93",
    "@microsoft/msgraph-sdk": "^1.0.0-preview.55",
    "@microsoft/msgraph-sdk-drives": "^1.0.0-preview.55"
  }
}
